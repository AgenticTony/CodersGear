@model IEnumerable<Product>

@{
    ViewData["Title"] = "T-Shirts";
}

<!-- Category Header -->
<div class="bg-primary text-white py-4 mb-4">
    <div class="container">
        <h1 class="mb-0">T-Shirts</h1>
        <p class="mb-0">Comfortable developer-themed t-shirts for coding in style</p>
    </div>
</div>

<!-- Empty State -->
@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-box-seam display-1 text-muted"></i>
        <p class="mt-3 text-muted">No T-Shirts available at the moment.</p>
    </div>
}
else
{
    <!-- Products Grid -->
    <div class="row pb-3">
        @foreach (var product in Model)
        {
            <div class="col-lg-3 col-sm-6">
                <div class="row p-2">
                    <div class="card mb-3">
                        <h3 class="card-header">@product.ProductName</h3>
                        <img src="@product.ImageUrl" class="class-img-top rounded-top"/>
                        <div class="card-body">
                            @Html.Raw(product.Description)
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <a asp-action="Details"
                                   asp-route-productId="@product.ProductId" class="btn btn-primary">See Details</a>
                                <a asp-action="BuyNow" asp-route-productId="@product.ProductId" class="btn btn-success">Buy Now</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
