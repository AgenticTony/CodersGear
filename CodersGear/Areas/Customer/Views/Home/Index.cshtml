@model IEnumerable<CategoryProductViewModel>

<!-- Hero Section -->
<div class="hero-section bg-primary text-white py-5 mb-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-4 fw-bold">Welcome to CodersGear</h1>
                <p class="lead mb-4">Your one-stop shop for developer apparel and accessories. Code in style with our premium collection!</p>
                <div class="d-flex gap-2">
                    <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-light btn-lg">Shop Now</a>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-light btn-lg">Manage Products</a>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <i class="bi bi-laptop display-1"></i>
            </div>
        </div>
    </div>
</div>

<!-- Empty State -->
@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-box-seam display-1 text-muted"></i>
        <p class="mt-3 text-muted">No products available at the moment.</p>
    </div>
}
else
{
    <!-- Products by Category -->
    @foreach (var categoryGroup in Model)
    {
        <div class="category-section mt-4">
            <h2 class="mb-3 text-secondary">
                <i class="bi"></i> @categoryGroup.CategoryName
            </h2>
            <div class="row pb-3">
                @foreach (var product in categoryGroup.Products)
                {
                    <div class="col-lg-3 col-sm-6">
                        <div class="row p-2">
                            <div class="card mb-3">
                                <h3 class="card-header">@product.ProductName</h3>
                                <img src="@product.ImageUrl" class="class-img-top rounded-top"/>
                                <div class="card-body">
                                    @Html.Raw(product.Description)
                                </div>
                                <div class="card-body">
                                    <div class="d-grid gap-2">
                                        <a asp-action="Details"
                                        asp-route-productId="@product.ProductId" class="btn btn-primary">See Details</a>
                                        <a href="#" class="btn btn-success">Buy Now</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
