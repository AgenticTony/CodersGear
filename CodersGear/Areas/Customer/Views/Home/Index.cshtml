@model IEnumerable<CategoryProductViewModel>

<!-- Modern Hero Section -->
<div class="hero-section position-relative overflow-hidden bg-gradient mb-4" style="
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 120px 0 80px;
">
    <!-- Animated background elements -->
    <div class="position-absolute top-0 start-0 w-100 h-100 overflow-hidden opacity-10">
        <div style="position: absolute; top: -50%; left: -20%; font-size: 400px; font-weight: bold; color: white;">&lt;/&gt;</div>
        <div style="position: absolute; bottom: -30%; right: -10%; font-size: 300px; font-weight: bold; color: white;">{ }</div>
        <div style="position: absolute; top: 20%; right: 10%; font-size: 200px; font-weight: bold; color: white;">( )</div>
        <div style="position: absolute; top: 60%; left: 10%; font-size: 150px; font-weight: bold; color: white;">;</div>
    </div>

    <div class="container position-relative" style="z-index: 1;">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="badge bg-white text-primary mb-3 px-3 py-2 rounded-pill fw-semibold">
                    🚀 New Season Available
                </div>
                <h1 class="display-3 fw-bold mb-3" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.2);">
                    Code in Style.<br>
                    <span style="color: #fbbf24;">Ship Bugs Faster.</span>
                </h1>
                <p class="lead mb-4 fs-5" style="opacity: 0.95;">
                    Premium developer apparel designed for those who turn coffee into code.
                    Comfortable, stylish, and built for marathon coding sessions.
                </p>
                <div class="d-flex gap-3 flex-wrap align-items-center">
                    <a asp-area="Customer" asp-controller="Home" asp-action="TShirts"
                       class="btn btn-light btn-lg px-4 py-3 fw-semibold shadow-lg hover-lift">
                        <i class="bi bi-tshirt me-2"></i> Shop T-Shirts
                    </a>
                    <a asp-area="Customer" asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-light btn-lg px-4 py-3 fw-semibold hover:bg-white hover:text-primary">
                        <i class="bi bi-grid me-2"></i> View All Products
                    </a>
                </div>
                <div class="mt-4 d-flex gap-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-truck fs-4 me-2"></i>
                        <span class="small">Free Shipping on $50+</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-arrow-counterclockwise fs-4 me-2"></i>
                        <span class="small">30-Day Returns</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-shield-check fs-4 me-2"></i>
                        <span class="small">Secure Checkout</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 text-center d-none d-lg-block">
                <div class="position-relative">
                    <div class="bg-white bg-opacity-10 rounded-3 p-4 backdrop-blur-sm">
                        <i class="bi bi-laptop" style="font-size: 180px; color: white;"></i>
                        <div class="mt-3">
                            <span class="badge bg-success text-white mb-2">Best Seller</span>
                            <p class="mb-1 fw-semibold">Coder's Gear T-Shirt</p>
                            <p class="fs-5 opacity-75">$23.99</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Wave SVG divider -->
    <div style="position: absolute; bottom: 0; left: 0; width: 100%;">
        <svg viewBox="0 0 1440 120" preserveAspectRatio="none" style="fill: #f8f9fa;">
            <path d="M0,64L1440,0L1440,120L0,120Z"></path>
        </svg>
    </div>
</div>

<style>
.hero-section .hover-lift {
    transition: all 0.3s ease;
}
.hero-section .hover-lift:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.3);
}
</style>

<!-- Empty State -->
@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-box-seam display-1 text-muted"></i>
        <p class="mt-3 text-muted">No products available at the moment.</p>
    </div>
}
else
{
    <!-- Products by Category -->
    @foreach (var categoryGroup in Model)
    {
        <div class="category-section mt-4">
            <h2 class="mb-3 text-secondary">
                <i class="bi"></i> @categoryGroup.CategoryName
            </h2>
            <div class="row pb-3">
                @foreach (var product in categoryGroup.Products)
                {
                    <div class="col-lg-3 col-sm-6">
                        <div class="row p-2">
                            <a asp-action="Details" asp-route-productId="@product.ProductId" class="text-decoration-none product-card-link">
                                <div class="card mb-3 h-100">
                                    <h3 class="card-header">@product.ProductName</h3>
                                    <img src="@product.ImageUrl" class="card-img-top rounded-top"/>
                                    <div class="card-body">
                                        @{
                                            var description = product.Description ?? "";
                                            var maxLength = 100;
                                            if (description.Length > maxLength)
                                            {
                                                description = description.Substring(0, maxLength) + "...";
                                            }
                                        }
                                        <p class="card-text text-muted">@Html.Raw(description)</p>
                                    </div>
                                    <div class="card-body mt-auto">
                                        <div class="d-grid gap-2">
                                            <span class="btn btn-primary">See Details</span>
                                            <a asp-action="BuyNow" asp-route-productId="@product.ProductId" class="btn btn-success"
                                               onclick="event.stopPropagation()">Buy Now</a>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
