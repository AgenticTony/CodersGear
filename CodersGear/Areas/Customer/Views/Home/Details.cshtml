@model ShoppingCart
@using CodersGear.Utility

@{
    ViewData["Title"] = Model.Product?.ProductName ?? "Product Details";

    // Determine the category action based on category name
    string categoryAction = "Index";
    if (Model.Product?.Category?.Name?.Contains("T-shirt") == true || Model.Product?.Category?.Name?.Contains("T-Shirt") == true)
    {
        categoryAction = "TShirts";
    }
    else if (Model.Product?.Category?.Name?.Contains("Hoodi") == true)
    {
        categoryAction = "Hoddies";
    }
    else if (Model.Product?.Category?.Name?.Contains("Mug") == true)
    {
        categoryAction = "Mugs";
    }
    else if (Model.Product?.Category?.Name?.Contains("Accessorie") == true)
    {
        categoryAction = "Accessories";
    }
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mt-3">
    
    <div class="container">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item">
                <a asp-area="Customer" asp-controller="Home" asp-action="@categoryAction" class="text-decoration-none">
                    @Model.Product?.Category?.Name
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Product?.ProductName</li>
        </ol>
    </div>
</nav>

<!-- Product Details Section -->
<div class="container py-4">
    <div class="row g-4">
        <!-- Product Image -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <img src="@(Model.Product?.ImageUrl ?? "/images/product/placeholder.png")"
                         class="img-fluid w-100 rounded"
                         alt="@Model.Product?.ProductName"
                         id="mainProductImage">
                </div>
            </div>

            <!-- Thumbnail Gallery -->
            <div class="row g-2 mt-2">
                <div class="col-3">
                    <div class="card">
                        <img src="@(Model.Product?.ImageUrl ?? "/images/product/placeholder.png")"
                             class="img-fluid rounded cursor-pointer"
                             alt="Thumbnail"
                             onclick="changeImage('@(Model.Product?.ImageUrl ?? "/images/product/placeholder.png")')">
                    </div>
                </div>
                <!-- More thumbnails can be added here -->
            </div>

            <!-- Stock Status Alert -->
            <div class="alert alert-success mt-3 d-flex align-items-center" role="alert">
                <i class="bi bi-check-circle-fill flex-shrink-0 me-2"></i>
                <div>
                    <strong>In Stock</strong> - Order now for fast shipping!
                </div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-lg-6">
            <form method="post" asp-action="Details">
                <input hidden asp-for="ProductId" />
                <div class="sticky-top" style="top: 80px;">
                    <h1 class="display-5 fw-bold mb-2">@Model.Product?.ProductName</h1>

                <!-- Rating -->
                <div class="mb-3">
                    <div class="text-warning">
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-half"></i>
                    </div>
                    <small class="text-muted">(4.5) · 128 reviews</small>
                </div>

                <!-- Price Section -->
                <div class="card mb-4 border-0 bg-light">
                    <div class="card-body">
                        <div class="d-flex align-items-baseline gap-2">
                            <span class="text-info text-decoration-line-through">@Model.Product?.ListPrice.ToString("C")</span>
                            <span class="display-6 fw-bold text-primary">@Model.Product?.Price.ToString("C")</span>
                            @{
                                decimal savings = 0m;
                                if (Model.Product != null)
                                {
                                    savings = Model.Product.ListPrice - Model.Product.Price;
                                }
                            }
                            <span class="badge bg-danger">Save @savings.ToString("C")</span>
                        </div>
                        <p class="text-success mb-0"><i class="bi bi-truck"></i> Free shipping on orders over $50</p>
                    </div>
                </div>

                <!-- Description -->
                <div class="card mb-4 border-0">
                    <div class="card-header bg-transparent">
                        <h6 class="mb-0"><i class="bi bi-file-text"></i> Description</h6>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.Product?.Description))
                        {
                            <div class="text-muted">
                                @Html.Raw(Model.Product.Description)
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No description available.</p>
                        }
                    </div>
                </div>

                <!-- Quantity & Add to Cart -->
                <div class="card mb-4 border-0">
                    <div class="card-body">
                        <div class="row g-2 align-items-center flex-nowrap">
                            <div class="col-auto">
                                <span class="fw-bold">Qty:</span>
                            </div>
                            <div class="col-auto">
                                <div class="input-group input-group-sm" style="width: 95px;">
                                    <button class="btn btn-outline-secondary" type="button" onclick="decreaseQty()">-</button>
                                    <input asp-for="Count" type="number" class="form-control text-center px-1" value="1" min="1" id="quantityInput" style="appearance: textfield; -moz-appearance: textfield;">
                                    <button class="btn btn-outline-secondary" type="button" onclick="increaseQty()">+</button>
                                </div>
                            </div>
                            <div class="col">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                </button>
                            </div>
                        </div>
                    </form>
                    </div>
                </div>

                <!-- Quick Info -->
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="bi bi-shield-check text-success fs-4"></i>
                                <p class="small mb-0">30 Day Guarantee</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="bi bi-arrow-return-left text-primary fs-4"></i>
                                <p class="small mb-0">30-Day Returns</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Back Button -->
                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Products
                </a>
            </div>
        </div>
    </div>

    <!-- Product Details Tabs -->
    <div class="row mt-5">
        <div class="col-12">
            <ul class="nav nav-tabs nav-fill" id="productTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="bulk-tab" data-bs-toggle="tab" data-bs-target="#bulk" type="button">
                        <i class="bi bi-tag-fill"></i> Bulk Pricing
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="specs-tab" data-bs-toggle="tab" data-bs-target="#specs" type="button">
                        <i class="bi bi-list-check"></i> Specifications
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button">
                        <i class="bi bi-chat-dots"></i> Reviews
                    </button>
                </li>
            </ul>

            <div class="tab-content p-4 border border-top-0 rounded-bottom" id="productTabsContent">
                <!-- Bulk Pricing Tab -->
                <div class="tab-pane fade show active" id="bulk" role="tabpanel">
@{
    decimal savings50 = 0m;
    decimal savings100 = 0m;
    if (Model.Product != null)
    {
        savings50 = Model.Product.Price - Model.Product.Price50;
        savings100 = Model.Product.Price - Model.Product.Price100;
    }
}
                    <div class="card border-0">
                        <div class="card-body p-0">
                            <table class="table table-striped mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Quantity</th>
                                        <th class="text-end">Price Per Item</th>
                                        <th class="text-end">You Save</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>1-50 items</td>
                                        <td class="text-end">@Model.Product?.Price.ToString("C")</td>
                                        <td class="text-end">-</td>
                                    </tr>
                                    <tr>
                                        <td>50-100 items</td>
                                        <td class="text-end text-success fw-bold">@Model.Product?.Price50.ToString("C")</td>
                                        <td class="text-end text-success">@savings50.ToString("C")</td>
                                    </tr>
                                    <tr>
                                        <td>100+ items</td>
                                        <td class="text-end text-success fw-bold">@Model.Product?.Price100.ToString("C")</td>
                                        <td class="text-end text-success">@savings100.ToString("C")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Specifications Tab -->
                <div class="tab-pane fade" id="specs" role="tabpanel">
                    <table class="table table-striped">
                        <tbody>
                            <tr>
                                <th scope="row">Product ID</th>
                                <td>@Model.Product?.ProductId</td>
                            </tr>
                            <tr>
                                <th scope="row">UPC</th>
                                <td>@Model.Product?.UPC</td>
                            </tr>
                            <tr>
                                <th scope="row">Category</th>
                                <td>@Model.Product?.Category?.Name</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Reviews Tab -->
                <div class="tab-pane fade" id="reviews" role="tabpanel">
                    <div class="text-center py-4">
                        <i class="bi bi-chat-square-quote display-4 text-muted"></i>
                        <p class="mt-3">Reviews coming soon!</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeImage(src) {
            document.getElementById('mainProductImage').src = src;
        }

        function increaseQty() {
            const input = document.getElementById('quantityInput');
            input.value = parseInt(input.value) + 1;
        }

        function decreaseQty() {
            const input = document.getElementById('quantityInput');
            if (parseInt(input.value) > 1) {
                input.value = parseInt(input.value) - 1;
            }
        }
    </script>
}
