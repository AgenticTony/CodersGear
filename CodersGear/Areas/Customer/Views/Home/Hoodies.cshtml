@model IEnumerable<Product>

@{
    ViewData["Title"] = "Hoodies";
}

<!-- Category Header -->
<div class="bg-primary text-white py-4 mb-4">
    <div class="container">
        <h1 class="mb-0">Hoodies</h1>
        <p class="mb-0">Cozy hoodies to keep you warm while coding</p>
    </div>
</div>

<!-- Empty State -->
@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-box-seam display-1 text-muted"></i>
        <p class="mt-3 text-muted">No Hoodies available at the moment.</p>
    </div>
}
else
{
    <!-- Products Grid -->
    <div class="row pb-3">
        @foreach (var product in Model)
        {
            <div class="col-lg-3 col-sm-6">
                <div class="card mb-3 h-100 border-0 shadow-sm d-flex flex-column">
                    <a asp-action="Details" asp-route-productId="@product.ProductId" class="text-decoration-none">
                        <img src="@product.ImageUrl" class="card-img-top rounded-top" style="object-fit: cover; width: 100%; height: 250px;"/>
                    </a>
                    <div class="card-body d-flex flex-column flex-grow-1">
                        @{
                            var description = product.Description ?? "";
                            var maxLength = 100;
                            if (description.Length > maxLength)
                            {
                                description = description.Substring(0, maxLength) + "...";
                            }
                        }
                        <p class="card-text text-muted small mb-2">@Html.Raw(description)</p>
                        <div class="mt-auto">
                            <div class="mb-2">
                                <span class="h5 text-dark fw-bold">$@product.Price.ToString("F2")</span>
                                @if (product.ListPrice > product.Price)
                                {
                                    <span class="text-decoration-line-through text-danger ms-2 small">$@product.ListPrice.ToString("F2")</span>
                                }
                            </div>
                            <div class="d-grid gap-2">
                                <a asp-action="Details" asp-route-productId="@product.ProductId" class="btn btn-primary py-2 fs-6">See Details</a>
                                <button type="button" class="btn btn-success py-2 quick-buy-btn"
                                    data-product-id="@product.ProductId"
                                    data-product-name="@product.ProductName"
                                    data-price="@product.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                    data-image-url="@product.ImageUrl"
                                    data-has-variants="@(product.IsPrintifyProduct && !string.IsNullOrEmpty(product.PrintifyOptionsData) ? "true" : "false")"
                                    data-variant-data="@product.PrintifyVariantData"
                                    data-options-data="@product.PrintifyOptionsData">
                                    Buy Now
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Quick Buy Modal -->
<partial name="~/Views/Shared/_QuickBuyModal.cshtml" />
