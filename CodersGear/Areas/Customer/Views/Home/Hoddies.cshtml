@model IEnumerable<Product>

@{
    ViewData["Title"] = "Hoodies";
}

<!-- Category Header -->
<div class="bg-primary text-white py-4 mb-4">
    <div class="container">
        <h1 class="mb-0">Hoodies</h1>
        <p class="mb-0">Cozy hoodies to keep you warm while coding</p>
    </div>
</div>

<!-- Empty State -->
@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-box-seam display-1 text-muted"></i>
        <p class="mt-3 text-muted">No Hoodies available at the moment.</p>
    </div>
}
else
{
    <!-- Products Grid -->
    <div class="row pb-3">
        @foreach (var product in Model)
        {
            <div class="col-lg-3 col-sm-6">
                <div class="row p-2">
                    <a asp-action="Details" asp-route-productId="@product.ProductId" class="text-decoration-none product-card-link">
                        <div class="card mb-3 h-100">
                            <h3 class="card-header">@product.ProductName</h3>
                            <img src="@product.ImageUrl" class="card-img-top rounded-top"/>
                            <div class="card-body">
                                @{
                                    var description = product.Description ?? "";
                                    var maxLength = 100;
                                    if (description.Length > maxLength)
                                    {
                                        description = description.Substring(0, maxLength) + "...";
                                    }
                                }
                                <p class="card-text text-muted">@Html.Raw(description)</p>
                            </div>
                            <div class="card-body mt-auto">
                                <div class="d-grid gap-2">
                                    <span class="btn btn-primary">See Details</span>
                                    <a asp-action="BuyNow" asp-route-productId="@product.ProductId" class="btn btn-success"
                                       onclick="event.stopPropagation()">Buy Now</a>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        }
    </div>
}
