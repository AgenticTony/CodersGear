@model CodersGear.Models.ViewModels.ShoppingCartVM
@{
    ViewData["Title"] = "Order Summary";
}

<div class="container py-5">
    <h1 class="mb-4">Order Summary</h1>

    @if (Model?.ShoppingCartList != null && Model.ShoppingCartList.Any())
    {
        <form asp-action="Summary" method="post" id="summaryForm">
            <div class="row">
                <!-- Customer & Shipping Information -->
                <div class="col-lg-8">
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>Shipping Information</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label asp-for="OrderHeader.Name" class="form-label">Name</label>
                                    <input asp-for="OrderHeader.Name" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <label asp-for="OrderHeader.PhoneNumber" class="form-label">Phone Number</label>
                                    <input asp-for="OrderHeader.PhoneNumber" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <label asp-for="OrderHeader.StreetAddress" class="form-label">Street Address</label>
                                    <input asp-for="OrderHeader.StreetAddress" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="OrderHeader.City" class="form-label">City</label>
                                    <input asp-for="OrderHeader.City" class="form-control" />
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="OrderHeader.State" class="form-label">State</label>
                                    <input asp-for="OrderHeader.State" class="form-control" />
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="OrderHeader.PostalCode" class="form-label">Postal Code</label>
                                    <input asp-for="OrderHeader.PostalCode" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <label asp-for="OrderHeader.Country" class="form-label">Country</label>
                                    <input asp-for="OrderHeader.Country" class="form-control" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Information (Stripe) -->
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-credit-card me-2"></i>Payment Information</h5>
                        </div>
                        <div class="card-body">
                            <div class="alert alert-success d-flex align-items-center" role="alert">
                                <i class="bi bi-shield-check-fill flex-shrink-0 me-2"></i>
                                <div>
                                    <strong>Secure Payment:</strong> Powered by <strong>Stripe</strong>. Your payment information is encrypted and secure.
                                </div>
                            </div>
                            <div class="d-flex align-items-center text-muted small">
                                <i class="bi bi-lock-fill me-2"></i>
                                <span>You'll be redirected to Stripe's secure checkout to complete your payment.</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Order Summary -->
                <div class="col-lg-4">
                    <div class="card shadow-sm position-sticky" style="top: 20px;">
                        <div class="card-header bg-success">
                            <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Order Summary</h5>
                        </div>
                        <div class="card-body">
                            <h6 class="mb-3">Products (@Model.ShoppingCartList.Count())</h6>

                            <!-- Order Items -->
                            <div class="mb-3" style="max-height: 300px; overflow-y: auto;">
                                @foreach (var item in Model.ShoppingCartList)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                        <div class="d-flex align-items-center">
                                            @if (item.Product != null)
                                            {
                                                <img src="@(item.Product.ImageUrl ?? "/images/product/placeholder.png")"
                                                     class="rounded me-2"
                                                     style="width: 40px; height: 40px; object-fit: cover;"
                                                     alt="@item.Product.ProductName" />
                                                <div>
                                                    <span class="d-block">@item.Product.ProductName</span>
                                                    <small class="text-muted">Qty: @item.Count</small>
                                                </div>
                                            }
                                        </div>
                                        <span class="fw-bold">@((item.Price * item.Count).ToString("C2", new System.Globalization.CultureInfo("en-US")))</span>
                                    </div>
                                }
                            </div>

                            <!-- Price Breakdown -->
                            <div class="border-top pt-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Subtotal</span>
                                    <span>@Model.OrderHeader.OrderTotal.ToString("C2", new System.Globalization.CultureInfo("en-US"))</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Shipping</span>
                                    <span class="text-success">FREE</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Estimated Arrival</span>
                                    <span class="text-muted small">@DateTime.Now.AddDays(7).ToShortDateString() - @DateTime.Now.AddDays(14).ToShortDateString()</span>
                                </div>
                                <div class="d-flex justify-content-between fw-bold fs-5 border-top pt-2">
                                    <span>Total</span>
                                    <span>@Model.OrderHeader.OrderTotal.ToString("C2", new System.Globalization.CultureInfo("en-US"))</span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-success w-100 btn-lg py-2 mt-3">
                                <i class="bi bi-credit-card me-2"></i> Proceed to Payment
                            </button>

                            <div class="mt-3 text-center">
                                <a asp-action="Index" asp-controller="Cart" class="btn btn-outline-secondary w-100">
                                    <i class="bi bi-arrow-left me-2"></i> Back to Cart
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <h3 class="mt-3">Your cart is empty</h3>
            <p class="text-muted">Add some items to your cart before checking out.</p>
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary">
                Continue Shopping
            </a>
        </div>
    }
</div>
