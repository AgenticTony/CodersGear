@model CodersGear.Models.ViewModels.ShoppingCartVM
@using Microsoft.AspNetCore.Identity
@using CodersGear.Models
@inject SignInManager<ApplicationUser> SignInManager
@{
    ViewData["Title"] = "Shopping Cart";
    bool isGuest = !SignInManager.IsSignedIn(User);
}

<h1 class="mb-4">Shopping Cart</h1>

@if (isGuest)
{
    <div class="alert alert-info d-flex align-items-center" role="alert">
        <i class="bi bi-info-circle-fill me-2 fs-4"></i>
        <div>
            <strong>Shopping as Guest</strong>
            <span class="d-block">Your cart is saved for this session. <a asp-area="Identity" asp-page="/Account/Login" class="alert-link">Log in</a> to save your cart permanently or proceed to checkout.</span>
        </div>
    </div>
}

@if (Model.ShoppingCartList != null && Model.ShoppingCartList.Any())
{
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ShoppingCartList)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (item.Product != null)
                                            {
                                                <img src="@(item.Product.ImageUrl ?? "/images/product/placeholder.png")"
                                                     class="rounded me-2"
                                                     style="width: 60px; height: 60px; object-fit: cover;"
                                                     alt="@item.Product.ProductName" />
                                                <div>
                                                    <h6 class="mb-0">@item.Product.ProductName</h6>
                                                    <small class="text-muted">@item.Product.Category?.Name</small>
                                                </div>
                                            }
                                            else
                                            {
                                                <span>Product not available</span>
                                            }
                                        </div>
                                    </td>
                                    <td>@item.Price.ToString("C2", new System.Globalization.CultureInfo("en-US"))</td>
                                    <td>
                                        <div class="input-group input-group-sm" style="width: 120px;">
                                            <a asp-action="Decrement" asp-controller="Cart" asp-route-id="@item.Id" class="btn btn-outline-secondary">-</a>
                                            <input type="text" class="form-control text-center" value="@item.Count" readonly />
                                            <a asp-action="Increment" asp-controller="Cart" asp-route-id="@item.Id" class="btn btn-outline-secondary">+</a>
                                        </div>
                                    </td>
                                    <td>@((item.Price * item.Count).ToString("C2", new System.Globalization.CultureInfo("en-US")))</td>
                                    <td>
                                        <form asp-action="Remove" asp-controller="Cart" method="post" asp-route-id="@item.Id">
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="bi bi-trash"></i> Remove
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Order Summary</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Total:</span>
                        <strong>@Model.OrderHeader.OrderTotal.ToString("C2", new System.Globalization.CultureInfo("en-US"))</strong>
                    </div>
                    <div class="d-grid gap-2">
                        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Continue Shopping</a>
                        @if (isGuest)
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Url.Action("Summary", "Cart", new { area = "Customer" })" class="btn btn-primary w-100">
                                <i class="bi bi-lock-fill"></i> Log In to Checkout
                            </a>
                        }
                        else
                        {
                            <a asp-action="Summary" asp-controller="Cart" class="btn btn-primary w-100">Proceed to Checkout</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-cart-x display-1 text-muted"></i>
        <h3 class="mt-3">Your cart is empty</h3>
        <p class="text-muted">Add some items to get started!</p>
        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary">
            Continue Shopping
        </a>
    </div>
}
