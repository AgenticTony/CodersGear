@model int
@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow">
                <div class="card-body py-5">
                    <i class="bi bi-check-circle-fill text-success display-1"></i>
                    <h2 class="mt-4">Order Placed Successfully!</h2>
                    <p class="text-muted">Thank you for your purchase.</p>

                    <div class="alert alert-info mt-4">
                        <strong>Order ID:</strong> #@Model
                    </div>

                    <p class="small text-muted mb-4">
                        You will receive a confirmation email shortly with your order details.
                    </p>

                    <div class="d-grid gap-2">
                        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary">
                            Continue Shopping
                        </a>
                        <a asp-area="Customer" asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">
                            View Cart
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
