@model ProductViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var categoryList = Model.CategoryDictionary
        .Select(kvp => new SelectListItem
        {
            Value = kvp.Key.ToString(),
            Text = kvp.Value
        })
        .ToList();
}

<form method="post" enctype="multipart/form-data">
    <input asp-for="Product.ProductId" hidden />
    <input asp-for="Product.ImageUrl" hidden />
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-secondary">@(Model.Product?.ProductId != 0 && Model.Product != null ? "Update" : "Create") Product</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly"></div>

        <!-- Product Name & Current Image -->
        <div class="mb-3 row">
            <div class="col-8">
                <label asp-for="Product.ProductName"></label>
                <input asp-for="Product.ProductName" type="text" class="form-control" />
                <span asp-validation-for="Product.ProductName" class="text-danger"></span>
            </div>
            <div class="col-4">
                @if (Model.Product != null && !string.IsNullOrEmpty(Model.Product.ImageUrl))
                {
                    <label>Current Image</label>
                    <img src="@Model.Product.ImageUrl" alt="Product Image" style="width: 100%; max-width: 150px; height: auto; border-radius: 5px; border: 1px solid #dee2e6;" />
                }
            </div>
        </div>

        <!-- Description -->
        <div class="mb-3 row">
            <label asp-for="Product.Description"></label>
            <textarea asp-for="Product.Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Product.Description" class="text-danger"></span>
        </div>

        <!-- UPC -->
        <div class="mb-3 row">
            <label asp-for="Product.UPC"></label>
            <input asp-for="Product.UPC" type="text" class="form-control" />
            <span asp-validation-for="Product.UPC" class="text-danger"></span>
        </div>

        <!-- List Price -->
        <div class="mb-3 row">
            <label asp-for="Product.ListPrice"></label>
            <input asp-for="Product.ListPrice" type="number" step="0.01" class="form-control" />
            <span asp-validation-for="Product.ListPrice" class="text-danger"></span>
        </div>

        <!-- Price -->
        <div class="mb-3 row">
            <label asp-for="Product.Price"></label>
            <input asp-for="Product.Price" type="number" step="0.01" class="form-control" />
            <span asp-validation-for="Product.Price" class="text-danger"></span>
        </div>

        <!-- Price50 -->
        <div class="mb-3 row">
            <label asp-for="Product.Price50"></label>
            <input asp-for="Product.Price50" type="number" step="0.01" class="form-control" />
            <span asp-validation-for="Product.Price50" class="text-danger"></span>
        </div>

        <!-- Price100 -->
        <div class="mb-3 row">
            <label asp-for="Product.Price100"></label>
            <input asp-for="Product.Price100" type="number" step="0.01" class="form-control" />
            <span asp-validation-for="Product.Price100" class="text-danger"></span>
        </div>

        <!-- Category Dropdown -->
        <div class="mb-3 row">
            <label asp-for="Product.CategoryId"></label>
            <select asp-for="Product.CategoryId" asp-items="categoryList" class="form-select">
                <option disabled selected>-- Select Category --</option>
            </select>
            <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
        </div>

        <!-- Image URL -->
        <div class="mb-3 row">
            <label asp-for="Product.ImageUrl"></label>
            <input type="file" name="file" class="form-control" />
            <span asp-validation-for="Product.ImageUrl" class="text-danger"></span>
        </div>

        <!-- Buttons -->
        <div class="row p-0">
            <div class="col-6 col-md-3 p-0">
                @if (Model.Product?.ProductId != 0 && Model.Product != null)
                {
                    <button type="submit" class="btn btn-primary form-control">Update</button>
                }
                else
                {
                        
                    <button type="submit" class="btn btn-primary form-control">Create</button>
                }
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Product" asp-action="Index" class="btn btn-secondary form-control">
                    Back To List
                </a>
            </div>
        </div>
    </div>
</form>

