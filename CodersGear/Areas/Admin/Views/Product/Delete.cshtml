@model Product

<form method="post">
    <input asp-for="ProductId" hidden />
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-secondary">Delete Product</h2>
            <hr />
        </div>

        <div class="mb-3 row">
            <label asp-for="ProductName"></label>
            <input asp-for="ProductName" disabled class="form-control" />
        </div>
        <div class="mb-3 row">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" disabled class="form-control" rows="3"></textarea>
        </div>
        <div class="mb-3 row">
            <label asp-for="Price"></label>
            <input asp-for="Price" disabled class="form-control" />
        </div>
        <div class="row p-0">
            <div class="col-6 col-md-3 p-0">
                <button type="submit" class="btn btn-danger form-control">Delete</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Product" asp-action="Index" class="btn btn-secondary form-control">
                    Back To List
                </a>
            </div>
        </div>
    </div>
</form>
